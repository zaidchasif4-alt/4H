<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>4H - Admin Portal</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-serif-luxury { font-family: 'Playfair Display', serif; }
        .material-symbols-outlined { font-size: 20px; }
        
        .nav-link { display:flex; align-items:center; gap:16px; padding:12px 16px; border-radius:6px; font-size:14px; font-weight:500; letter-spacing:.03em; transition:all .2s; color:#a1a1aa; }
        .nav-link:hover { background:#18181b; color:#fff; }
        .nav-link .icon { color:#52525b; transition:color .2s; font-size:20px; }
        .nav-link:hover .icon { color:#fff; }
        .nav-link.active { background:#18181b; color:#fff; }
        .nav-link.active .icon { color:#b8975a; }

        @media (max-width: 1023px) {
            .sidebar-closed { transform: translateX(-100%); }
            .sidebar-open { transform: translateX(0); }
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 antialiased min-h-screen lg:flex">

    <!-- Mobile top bar -->
    <div class="lg:hidden h-16 bg-black text-white px-4 flex items-center justify-between sticky top-0 z-50 shadow">
        <span class="text-xl tracking-widest font-serif-luxury font-medium">4H</span>
        <button id="mobile-menu-toggle" class="p-2 text-zinc-400 hover:text-white focus:outline-none">
            <span class="material-symbols-outlined text-2xl" id="menu-icon">menu</span>
        </button>
    </div>

    <!-- Sidebar -->
    <aside id="admin-sidebar" class="w-64 bg-black text-white flex flex-col fixed inset-y-0 left-0 z-50 lg:z-40 lg:translate-x-0 sidebar-closed transition-transform duration-300 ease-in-out lg:pt-0 pt-16">
        
        <!-- Logo -->
        <div class="h-20 hidden lg:flex items-center justify-between px-6 border-b border-zinc-800">
            <span class="text-2xl tracking-widest font-serif-luxury font-medium">4H</span>
            <span class="text-[10px] bg-zinc-800 text-zinc-400 tracking-widest uppercase px-2 py-0.5 rounded font-mono">Admin</span>
        </div>

        <!-- Nav links -->
        <nav class="flex-grow py-6 lg:py-8 px-4 space-y-1 overflow-y-auto">

            <a href="/admin" id="nav-dashboard" class="nav-link">
                <span class="material-symbols-outlined icon">dashboard</span>
                <span>Dashboard</span>
            </a>

            <a href="/admin/products" id="nav-products" class="nav-link">
                <span class="material-symbols-outlined icon">shopping_bag</span>
                <span>Products List</span>
            </a>

            <a href="/admin/add-product" id="nav-add" class="nav-link">
                <span class="material-symbols-outlined icon">add_circle</span>
                <span>Add New Product</span>
            </a>

            <a href="/admin/categories" id="nav-categories" class="nav-link">
                <span class="material-symbols-outlined icon">category</span>
                <span>Categories</span>
            </a>

            <!-- Settings link -->
            <a href="/admin/settings" id="nav-settings" class="nav-link">
                <span class="material-symbols-outlined icon">tune</span>
                <span>Site Settings</span>
            </a>

            <!-- Change credentials -->
            <a href="/admin/credentials" id="nav-credentials" class="nav-link">
                <span class="material-symbols-outlined icon">lock</span>
                <span>Change Password</span>
            </a>

        </nav>

        <!-- Bottom buttons -->
        <div class="p-4 border-t border-zinc-800 bg-black space-y-2">
            <a href="/" target="_blank" class="flex items-center justify-center gap-2 w-full py-2.5 bg-zinc-900 hover:bg-zinc-800 text-xs text-zinc-300 font-medium uppercase tracking-widest transition-colors rounded">
                <span>View Live Store</span>
                <span class="material-symbols-outlined" style="font-size:14px;">open_in_new</span>
            </a>
            <a href="/admin/logout" class="flex items-center justify-center gap-2 w-full py-2.5 bg-transparent hover:bg-red-900/30 text-xs text-red-500 hover:text-red-400 font-medium uppercase tracking-widest transition-colors rounded border border-red-900/30">
                <span class="material-symbols-outlined" style="font-size:14px;">logout</span>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Overlay (mobile) -->
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden"></div>

    <!-- Main content area -->
    <div class="flex-grow lg:pl-64 flex flex-col min-h-screen w-full overflow-x-hidden">
        
        <!-- Top header bar -->
        <header class="h-20 bg-white border-b border-gray-100 sticky top-0 z-30 hidden lg:flex items-center justify-between px-8 shadow-sm">
            <div>
                <h2 class="text-xs text-gray-400 font-semibold uppercase tracking-widest">Control Panel</h2>
            </div>
            <div class="flex items-center gap-4">
                <a href="/admin/settings" class="flex items-center gap-1.5 text-xs text-gray-500 hover:text-black transition-colors px-3 py-1.5 rounded border border-gray-200 hover:border-black">
                    <span class="material-symbols-outlined" style="font-size:15px;">tune</span>
                    <span>Settings</span>
                </a>
                <div class="w-8 h-8 rounded-full bg-zinc-900 text-white flex items-center justify-center text-xs font-semibold">A</div>
                <span class="text-sm font-medium text-gray-700">Administrator</span>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-grow p-4 sm:p-6 lg:p-8 max-w-7xl w-full mx-auto">
            <%- body %>
        </main>
    </div>

    <script>
        // Mobile menu toggle
        const menuToggleBtn = document.getElementById('mobile-menu-toggle');
        const sidebarElement = document.getElementById('admin-sidebar');
        const overlayElement = document.getElementById('sidebar-overlay');
        const menuIcon = document.getElementById('menu-icon');

        function toggleMenu() {
            const closed = sidebarElement.classList.contains('sidebar-closed');
            sidebarElement.classList.toggle('sidebar-closed', !closed);
            sidebarElement.classList.toggle('sidebar-open', closed);
            overlayElement.classList.toggle('hidden', !closed);
            menuIcon.textContent = closed ? 'close' : 'menu';
        }
        menuToggleBtn.addEventListener('click', toggleMenu);
        overlayElement.addEventListener('click', toggleMenu);

        // Active nav link highlight
        const path = window.location.pathname;
        const map = {
            '/admin':                'nav-dashboard',
            '/admin/dashboard':      'nav-dashboard',
            '/admin/products':       'nav-products',
            '/admin/add-product':    'nav-add',
            '/admin/categories':     'nav-categories',
            '/admin/settings':       'nav-settings',
            '/admin/credentials':    'nav-credentials',
        };
        // Also match edit-product path
        let activeId = map[path];
        if (!activeId && path.startsWith('/admin/edit-product')) activeId = 'nav-products';
        if (activeId) {
            const el = document.getElementById(activeId);
            if (el) el.classList.add('active');
        }
    </script>

</body>
</html>
