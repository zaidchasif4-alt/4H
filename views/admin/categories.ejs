<div class="space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-serif-luxury font-medium text-gray-900">Categories</h1>
            <p class="text-sm text-gray-500 mt-1">Manage your watch collection categories.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Add Category Form -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm h-fit">
            <h2 class="text-sm font-semibold text-gray-800 uppercase tracking-widest mb-5">Add New Category</h2>
            <form action="/admin/categories" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-widest text-gray-500 mb-2">Category Name *</label>
                    <input
                        type="text"
                        name="name"
                        required
                        placeholder="e.g. Chronograph, Dress Watch"
                        class="w-full px-4 py-3 border border-gray-200 rounded text-sm focus:outline-none focus:border-black transition-colors"
                    />
                </div>
                <button type="submit"
                    class="w-full bg-black hover:bg-zinc-800 text-white text-xs font-bold uppercase tracking-widest py-3 rounded transition-colors">
                    Add Category
                </button>
            </form>
        </div>

        <!-- Categories Table -->
        <div class="lg:col-span-2 bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex items-center justify-between">
                <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500">Active Categories</h2>
                <span class="text-xs text-gray-400"><%= categories ? categories.length : 0 %> total</span>
            </div>

            <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                <div class="divide-y divide-gray-50">
                    <% categories.forEach(cat => { %>
                        <div class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors group">
                            <div>
                                <p class="text-sm font-medium text-gray-900"><%= cat.name %></p>
                                <p class="text-xs text-gray-400 font-mono mt-0.5">/<%= cat.slug %></p>
                            </div>
                            <div class="flex items-center gap-2">
                                <a href="/collection?cat=<%= cat.slug %>" target="_blank"
                                   class="text-xs text-gray-400 hover:text-black transition-colors px-3 py-1.5 rounded border border-gray-200 hover:border-black opacity-0 group-hover:opacity-100">
                                    View
                                </a>
                                <!-- DELETE BUTTON — FIXED -->
                                <form action="/admin/categories/delete/<%= cat._id %>" method="POST"
                                      onsubmit="return confirm('Delete category: <%= cat.name %>? This will NOT delete products in this category.')">
                                    <button type="submit"
                                        class="flex items-center justify-center w-8 h-8 rounded text-gray-300 hover:text-red-600 hover:bg-red-50 transition-all">
                                        <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="px-6 py-16 text-center">
                    <span class="material-symbols-outlined text-gray-200 block mb-3" style="font-size:40px;">category</span>
                    <p class="text-sm text-gray-400">No categories yet. Add your first one.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
