<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Admin Login — 4H</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400&family=Tenor+Sans&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Tenor Sans', sans-serif; }
        .font-display { font-family: 'Cormorant Garamond', serif; }
        input:-webkit-autofill { -webkit-box-shadow: 0 0 0 30px #0a0a0a inset !important; -webkit-text-fill-color: #faf9f7 !important; }
    </style>
</head>
<body class="bg-[#0a0a0a] min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm">

        <!-- Logo -->
        <div class="text-center mb-10">
            <h1 class="font-display text-5xl font-light tracking-[0.5em] text-[#faf9f7] uppercase mb-1">4H</h1>
            <p class="text-[8px] uppercase tracking-[0.6em] text-[#b8975a]">Admin Portal</p>
        </div>

        <!-- Error message -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 px-4 py-3 border border-red-800 bg-red-900/20 text-red-400 text-[11px] uppercase tracking-widest text-center rounded">
                <%= error %>
            </div>
        <% } %>

        <!-- Login form -->
        <form action="/admin/login" method="POST" class="space-y-4">

            <div>
                <label class="block text-[9px] uppercase tracking-[0.35em] text-[#6b6560] mb-2">Username</label>
                <input
                    type="text"
                    name="username"
                    required
                    autocomplete="username"
                    class="w-full bg-[#111] border border-[#2a2a2a] text-[#faf9f7] px-4 py-3 text-sm focus:outline-none focus:border-[#b8975a] transition-colors rounded"
                    placeholder="Enter username"
                />
            </div>

            <div>
                <label class="block text-[9px] uppercase tracking-[0.35em] text-[#6b6560] mb-2">Password</label>
                <div class="relative">
                    <input
                        type="password"
                        name="password"
                        id="pwdInput"
                        required
                        autocomplete="current-password"
                        class="w-full bg-[#111] border border-[#2a2a2a] text-[#faf9f7] px-4 py-3 pr-12 text-sm focus:outline-none focus:border-[#b8975a] transition-colors rounded"
                        placeholder="Enter password"
                    />
                    <button type="button" onclick="togglePwd()" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#6b6560] hover:text-[#b8975a] transition-colors focus:outline-none">
                        <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <button type="submit"
                class="w-full bg-[#b8975a] hover:bg-[#d4b483] text-[#0a0a0a] py-3 text-[10px] uppercase tracking-[0.3em] font-bold transition-all duration-300 rounded mt-2">
                Sign In
            </button>
        </form>

        <p class="text-center text-[9px] uppercase tracking-[0.3em] text-[#2a2a2a] mt-10">
            4H Timepieces — Secure Admin
        </p>
    </div>

    <script>
        function togglePwd() {
            const input = document.getElementById('pwdInput');
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>
