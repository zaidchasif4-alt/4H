<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Edit Product — 4H Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family:'Inter',sans-serif; background:#f8f8f8; }
        .input-field { width:100%; border:1px solid #e5e7eb; padding:10px 14px; font-size:13px; border-radius:4px; outline:none; background:white; transition:border .2s; }
        .input-field:focus { border-color:#0a0a0a; }
        .label { font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.15em; color:#6b7280; margin-bottom:6px; display:block; }
    </style>
</head>
<body>
<div class="max-w-3xl mx-auto px-6 py-10">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 style="font-size:22px;font-weight:700;color:#0a0a0a;">Edit Product</h1>
            <p style="font-size:12px;color:#6b7280;margin-top:4px;">Update product details below.</p>
        </div>
        <a href="/admin/products" style="font-size:11px;color:#6b7280;text-decoration:underline;">← Back to Products</a>
    </div>

    <form action="/admin/edit-product/<%= product._id %>" method="POST" class="space-y-6">

        <div class="bg-white rounded-lg p-6 border border-gray-100 shadow-sm space-y-5">
            <div>
                <label class="label">Product Title *</label>
                <input type="text" name="title" value="<%= product.title %>" required class="input-field" placeholder="e.g. Royal Oak Chronograph"/>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="label">Base Price (PKR) *</label>
                    <input type="number" name="basePrice" value="<%= product.basePrice %>" required class="input-field" placeholder="e.g. 45000"/>
                </div>
                <div>
                    <label class="label">Sale Price (PKR)</label>
                    <input type="number" name="salePrice" value="<%= product.salePrice || '' %>" class="input-field" placeholder="Leave blank if not on sale"/>
                </div>
            </div>

            <div>
                <label class="label">Description</label>
                <textarea name="description" class="input-field" rows="4" placeholder="Product description..."><%= product.description %></textarea>
            </div>

            <div>
                <label class="label">Category</label>
                <select name="category" class="input-field">
                    <option value="">No Category</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= (product.category && product.category._id && product.category._id.toString() === cat._id.toString()) ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>
                    <% }); %>
                </select>
            </div>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-100 shadow-sm space-y-5">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:#0a0a0a;">Images</p>
            <div>
                <label class="label">Main Card Image URL *</label>
                <input type="text" name="cardImageUrl" value="<%= product.cardImageUrl %>" class="input-field" placeholder="https://..." id="mainImgInput" oninput="previewMain(this.value)"/>
                <img id="mainImgPreview" src="<%= product.cardImageUrl %>" class="mt-3 h-32 object-cover rounded border border-gray-100" onerror="this.style.display='none'" style="<%= product.cardImageUrl ? '' : 'display:none' %>"/>
            </div>

            <div>
                <label class="label">Extra Images (one URL per line)</label>
                <textarea name="extraImages" class="input-field" rows="4" placeholder="https://image2.jpg&#10;https://image3.jpg"><% if(product.images && product.images.length > 1) { %><%= product.images.slice(1).join('\n') %><% } %></textarea>
            </div>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-100 shadow-sm">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:#0a0a0a;margin-bottom:16px;">Visibility</p>
            <div class="flex flex-col gap-3">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="showOnHomeScreen" value="on" <%= product.showOnHomeScreen ? 'checked' : '' %> class="w-4 h-4"/>
                    <span style="font-size:12px;color:#374151;">Show on Home Screen (Featured)</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" name="isOnSale" value="on" <%= product.isOnSale ? 'checked' : '' %> class="w-4 h-4"/>
                    <span style="font-size:12px;color:#374151;">Mark as On Sale</span>
                </label>
            </div>
        </div>

        <div class="flex items-center justify-between">
            <form action="/admin/delete-product/<%= product._id %>" method="POST" onsubmit="return confirm('Delete this product?')">
                <button type="submit" style="background:#fee2e2;color:#dc2626;padding:10px 20px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;border:none;border-radius:4px;cursor:pointer;">
                    Delete Product
                </button>
            </form>
            <button type="submit" style="background:#0a0a0a;color:white;padding:12px 32px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.15em;border:none;border-radius:4px;cursor:pointer;">
                Save Changes
            </button>
        </div>
    </form>
</div>
<script>
function previewMain(url) {
    const img = document.getElementById('mainImgPreview');
    if (!url) { img.style.display = 'none'; return; }
    img.src = url; img.style.display = 'block';
    img.onerror = () => img.style.display = 'none';
}
</script>
</body>
</html>
