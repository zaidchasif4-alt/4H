<div class="space-y-8 max-w-lg">

    <div>
        <h1 class="text-2xl font-serif-luxury font-medium text-gray-900">Change Credentials</h1>
        <p class="text-sm text-gray-500 mt-1">Update your admin username and password.</p>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="px-4 py-3 bg-green-50 border border-green-200 text-green-700 text-xs uppercase tracking-widest rounded">
            ✓ Credentials updated successfully. Please log in again.
        </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="px-4 py-3 bg-red-50 border border-red-200 text-red-700 text-xs uppercase tracking-widest rounded">
            <%= error %>
        </div>
    <% } %>

    <form action="/admin/change-credentials" method="POST" class="bg-white border border-gray-100 rounded-lg p-6 shadow-sm space-y-5">

        <div>
            <label class="block text-[10px] font-semibold uppercase tracking-widest text-gray-500 mb-2">New Username</label>
            <input type="text" name="newUsername" required
                class="w-full border border-gray-200 px-4 py-3 text-sm rounded focus:outline-none focus:border-black transition-colors"
                placeholder="Enter new username"/>
        </div>

        <div>
            <label class="block text-[10px] font-semibold uppercase tracking-widest text-gray-500 mb-2">New Password</label>
            <input type="password" name="newPassword" required minlength="6"
                class="w-full border border-gray-200 px-4 py-3 text-sm rounded focus:outline-none focus:border-black transition-colors"
                placeholder="Min 6 characters"/>
        </div>

        <div>
            <label class="block text-[10px] font-semibold uppercase tracking-widest text-gray-500 mb-2">Current Password (to confirm)</label>
            <input type="password" name="currentPassword" required
                class="w-full border border-gray-200 px-4 py-3 text-sm rounded focus:outline-none focus:border-black transition-colors"
                placeholder="Enter current password to verify"/>
        </div>

        <button type="submit"
            class="w-full bg-black hover:bg-zinc-800 text-white text-[10px] uppercase tracking-widest font-bold py-3 rounded transition-colors">
            Update Credentials
        </button>
    </form>

    <p class="text-xs text-gray-400">After saving, you will be logged out and redirected to the login page.</p>
</div>
