<main class="p-6 decimal-matrix-frame">
    <div class="mb-6 flex justify-between items-center border-b border-gray-100 pb-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Add New Product</h1>
            <p class="text-sm text-gray-500 mt-1">Insert premium inventory assets into global store architecture.</p>
        </div>
    </div>

    <div class="max-w-3xl bg-white p-8 rounded-xl border border-gray-200 shadow-sm">
        <form action="/admin/add-product" method="POST" class="space-y-6">
            
            <div>
                <label for="title" class="block text-xs font-medium uppercase tracking-wider text-gray-600 mb-2">
                    Product Title / Name
                </label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    placeholder="e.g., AeroGraph Chrono Maverick Edition" 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="md:col-span-1">
                    <label for="basePrice" class="block text-xs font-medium uppercase tracking-wider text-gray-600 mb-2">
                        Base Price (PKR)
                    </label>
                    <input 
                        type="number" 
                        id="basePrice" 
                        name="basePrice" 
                        placeholder="e.g., 24500" 
                        required
                        class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                    />
                </div>

                <div class="md:col-span-1">
                    <label for="salePrice" class="block text-xs font-medium uppercase tracking-wider text-zinc-600 mb-2">
                        Sale Price (PKR) - Optional
                    </label>
                    <input 
                        type="number" 
                        id="salePrice" 
                        name="salePrice" 
                        placeholder="e.g., 19999" 
                        class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                    />
                </div>

                <div class="md:col-span-1">
                    <label for="category" class="block text-xs font-medium uppercase tracking-wider text-gray-600 mb-2">
                        Inventory Category Cluster
                    </label>
                    <select 
                        id="category" 
                        name="category" 
                        required
                        class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                    >
                        <option value="" disabled selected>Select a structural category node</option>
                        <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                            <% for (let i = 0; i < categories.length; i++) { %>
                                <option value="<%= categories[i]._id %>"><%= categories[i].name %></option>
                            <% } %>
                        <% } %>
                    </select>
                </div>
            </div>

            <div>
                <label for="cardImageUrl" class="block text-xs font-medium uppercase tracking-wider text-gray-600 mb-2">
                    Card Display Image URL (Main Image)
                </label>
                <input 
                    type="url" 
                    id="cardImageUrl" 
                    name="cardImageUrl" 
                    placeholder="https://images.unsplash.com/photo-..." 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                />
            </div>

            <div class="bg-zinc-50/50 p-5 rounded-xl border border-gray-200/60 space-y-4">
                <label class="block text-xs font-bold uppercase tracking-widest text-zinc-700">
                    Product Detail Gallery Images (Thumbnails)
                </label>
                <p class="text-xs text-gray-400 -mt-2">Provide extra detail configuration vectors for desktop left and mobile grid layout nodes.</p>
                
                <div class="space-y-3">
                    <input 
                        type="url" 
                        name="extraImages" 
                        placeholder="Gallery Detail Image URL 1" 
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-black transition-all"
                    />
                    <input 
                        type="url" 
                        name="extraImages" 
                        placeholder="Gallery Detail Image URL 2" 
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-black transition-all"
                    />
                    <input 
                        type="url" 
                        name="extraImages" 
                        placeholder="Gallery Detail Image URL 3" 
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-black transition-all"
                    />
                </div>
            </div>

            <div>
                <label for="description" class="block text-xs font-medium uppercase tracking-wider text-gray-600 mb-2">
                    Detailed Architecture Description
                </label>
                <textarea 
                    id="description" 
                    name="description" 
                    rows="4" 
                    placeholder="Describe premium specifications, material composition, structural parameters..." 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition-all duration-200"
                ></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex items-center space-x-3 bg-zinc-50 p-4 rounded-lg border border-gray-200/80">
                    <input 
                        type="checkbox" 
                        id="isOnSale" 
                        name="isOnSale" 
                        value="true"
                        class="h-4 w-4 text-black focus:ring-black border-gray-300 rounded accent-black cursor-pointer"
                    />
                    <label for="isOnSale" class="text-xs font-medium uppercase tracking-wider text-gray-700 select-none cursor-pointer">
                        Activate Flash Sale Variant Rules for this asset
                    </label>
                </div>

                <div class="flex items-center space-x-3 bg-gray-50 p-4 rounded-lg border border-gray-100">
                    <input 
                        type="checkbox" 
                        id="showOnHomeScreen" 
                        name="showOnHomeScreen" 
                        value="true"
                        class="h-4 w-4 text-black focus:ring-black border-gray-300 rounded accent-black cursor-pointer"
                    />
                    <label for="showOnHomeScreen" class="text-xs font-medium uppercase tracking-wider text-gray-700 select-none cursor-pointer">
                        Publish Configuration Matrix onto Storefront Homepage Grid
                    </label>
                </div>
            </div>

            <div class="pt-2">
                <button 
                    type="submit" 
                    class="w-full md:w-auto bg-black hover:bg-gray-900 text-white font-medium text-sm px-8 py-3 rounded-lg transition-all duration-200 shadow-sm"
                >
                    Publish Product Asset
                </button>
            </div>
        </form>
    </div>
</main>