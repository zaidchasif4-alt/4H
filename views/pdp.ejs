<!DOCTYPE html>
<html class="scroll-smooth" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    
    <% 
    // === MONGOOSE DYNAMIC FALLBACK VARIABLES CONTEXT ===
    // Database schema variables map seamlessly back to standard premium UI parameters
    const mainImage = product.cardImage;
    const imagesArray = (product.pdpImages && product.pdpImages.length > 0) ? product.pdpImages : [product.cardImage];
    const displayPrice = (product.isOnSale && product.salePrice) ? product.salePrice : product.basePrice;
    %>

    <title><%= product.name %> - 4H</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        .material-symbols-outlined {
            font-family: 'Material Symbols Outlined';
            font-weight: normal;
            font-style: normal;
            font-size: 24px;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
        }

        @media (max-width: 767px) {
            .desktop-only { display: none !important; }
            body { padding-bottom: 6rem; }
        }

        @media (min-width: 768px) {
            .mobile-only { display: none !important; }
        }
    </style>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "surface-container-lowest": "#ffffff",
                        "surface-bright": "#f9f9f9",
                        "on-surface": "#1a1c1c",
                        "surface-container-highest": "#e2e2e2",
                        "surface-dim": "#dadada",
                        "primary-container": "#1c1b1b",
                        "tertiary-fixed": "#e3e2e2",
                        "surface-container-low": "#f3f3f4",
                        "on-primary-container": "#858383",
                        "surface-container-high": "#e8e8e8",
                        "tertiary": "#000000",
                        "on-tertiary-fixed": "#1a1c1c",
                        "on-surface-variant": "#444748",
                        "on-secondary": "#ffffff",
                        "outline": "#747878",
                        "surface": "#f9f9f9",
                        "primary-fixed-dim": "#c9c6c5",
                        "secondary-fixed-dim": "#c6c6c7",
                        "error-container": "#ffdad6",
                        "inverse-on-surface": "#f0f1f1",
                        "tertiary-fixed-dim": "#c7c6c6",
                        "on-primary-fixed": "#1c1b1b",
                        "error": "#ba1a1a",
                        "surface-variant": "#e2e2e2",
                        "secondary": "#5d5f5f",
                        "inverse-surface": "#2f3131",
                        "tertiary-container": "#1a1c1c",
                        "on-tertiary-container": "#838484",
                        "on-error": "#ffffff",
                        "on-background": "#1a1c1c",
                        "outline-variant": "#c4c7c7",
                        "on-primary": "#ffffff",
                        "surface-container": "#eeeeee",
                        "primary-fixed": "#e5e2e1",
                        "on-tertiary-fixed-variant": "#464747",
                        "on-secondary-fixed": "#1a1c1c",
                        "secondary-container": "#dcdddd",
                        "inverse-primary": "#c9c6c5",
                        "primary": "#000000",
                        "on-error-container": "#93000a",
                        "on-tertiary": "#ffffff",
                        "on-secondary-fixed-variant": "#454747",
                        "secondary-fixed": "#e2e2e2",
                        "on-primary-fixed-variant": "#474646",
                        "surface-tint": "#5f5e5e",
                        "on-secondary-container": "#5f6161",
                        "background": "#f9f9f9"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "section-gap": "160px",
                        "unit": "8px",
                        "margin-tablet": "40px",
                        "margin-desktop": "80px",
                        "margin-mobile": "20px",
                        "gutter": "32px",
                        "container-max-width": "1440px"
                    },
                    "fontFamily": {
                        "label-caps": ["Inter"],
                        "headline-lg-mobile": ["Playfair Display"],
                        "headline-lg": ["Playfair Display"],
                        "headline-md": ["Playfair Display"],
                        "headline-display": ["Playfair Display"],
                        "body-md": ["Inter"],
                        "label-md": ["Inter"],
                        "body-lg": ["Inter"]
                    },
                    "fontSize": {
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.15em", "fontWeight": "600" }],
                        "headline-lg-mobile": ["32px", { "lineHeight": "40px", "fontWeight": "400" }],
                        "headline-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.01em", "fontWeight": "400" }],
                        "headline-md": ["32px", { "lineHeight": "40px", "fontWeight": "400" }],
                        "headline-display": ["80px", { "lineHeight": "90px", "letterSpacing": "-0.02em", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "label-md": ["14px", { "lineHeight": "20px", "fontWeight": "500" }],
                        "body-lg": ["18px", { "lineHeight": "32px", "letterSpacing": "0.01em", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-surface-container-lowest text-on-surface font-body-md min-h-screen flex flex-col antialiased selection:bg-primary selection:text-on-primary">

    <%- include('partials/header') %>

    <main class="desktop-only flex-grow pt-48 pb-section-gap">
        <div class="max-w-container-max-width mx-auto px-margin-desktop">
            <div class="grid grid-cols-12 gap-gutter items-start">
                
                <div class="col-span-7 flex gap-6 sticky top-48">
                    <div class="flex flex-col gap-4 w-24">
                        <% imagesArray.forEach((imgUrl, index) => { %>
                            <button class="thumbnail-btn w-full aspect-[4/5] bg-surface-container-high overflow-hidden focus:outline-none transition-all rounded duration-300 <%= index === 0 ? 'ring-1 ring-primary ring-offset-2 opacity-100' : 'opacity-60 hover:opacity-100' %>" 
                                    data-target-src="<%= imgUrl %>">
                                <img alt="Product Thumbnail <%= index + 1 %>" class="w-full h-full object-cover" src="<%= imgUrl %>" />
                            </button>
                        <% }) %>
                    </div>
                    
                    <div class="w-full aspect-[4/5] bg-surface-container-high overflow-hidden rounded-lg shadow-sm">
                        <img id="desktop-main-img" alt="<%= product.name %> Main Image" class="w-full h-full object-cover object-center transition-all duration-500" src="<%= mainImage %>" />
                    </div>
                </div>
                
                <div class="col-span-5 flex flex-col pl-8 sticky top-48">
                    <h1 class="font-headline-display text-headline-display text-primary mb-6"><%= product.name %></h1>
                    
                    <div class="mb-12 font-body-lg text-body-lg tracking-tight">
                        <% if(product.isOnSale && product.salePrice) { %>
                            <span class="text-red-600 font-semibold">$<%= product.salePrice.toLocaleString() %></span>
                            <del class="text-secondary ml-3 text-sm font-normal font-sans shadow-none">$<%= product.basePrice.toLocaleString() %></del>
                        <% } else { %>
                            <span class="text-secondary">$<%= product.basePrice.toLocaleString() %></span>
                        <% } %>
                    </div>

                    <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed max-w-md mb-16">
                        <%= product.description %>
                    </p>
                    
                    <form action="/add-to-cart" method="POST" class="mt-auto pt-8 border-t border-outline-variant/30 cart-form">
                        <input type="hidden" name="id" value="<%= product._id %>">
                        <input type="hidden" name="name" value="<%= product.name %>">
                        <input type="hidden" name="price" value="<%= displayPrice %>">
                        <input type="hidden" name="image" id="desktop-form-img" value="<%= mainImage %>">
                        
                        <button type="submit" class="w-full py-6 flex justify-between items-center group">
                            <span class="font-label-caps text-label-caps text-primary uppercase tracking-widest group-hover:underline underline-offset-8">Add to Bag</span>
                            <span class="material-symbols-outlined text-primary group-hover:translate-x-2 transition-transform">arrow_forward</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <main class="mobile-only pt-24 px-margin-mobile mb-16">
        <div class="w-full aspect-[4/5] bg-surface-container-highest mb-4 overflow-hidden rounded-lg">
            <img id="mobile-main-img" alt="<%= product.name %>" class="w-full h-full object-cover object-center transition-all duration-500" src="<%= mainImage %>" />
        </div>
        
        <div class="grid grid-cols-4 gap-3 mb-8">
            <% imagesArray.forEach((imgUrl, index) => { %>
                <button class="mobile-thumbnail-btn aspect-[4/5] bg-surface-container-high overflow-hidden focus:outline-none rounded transition-all duration-300 <%= index === 0 ? 'ring-1 ring-primary opacity-100' : 'opacity-60' %>" 
                        data-target-src="<%= imgUrl %>">
                    <img alt="Mobile Thumbnail" class="w-full h-full object-cover" src="<%= imgUrl %>" />
                </button>
            <% }) %>
        </div>

        <div class="mb-12">
            <h1 class="font-headline-lg-mobile text-headline-lg-mobile text-primary mb-2"><%= product.name %></h1>
            
            <div class="mb-6 font-body-lg text-body-lg">
                <% if(product.isOnSale && product.salePrice) { %>
                    <span class="text-red-600 font-semibold">$<%= product.salePrice.toLocaleString() %></span>
                    <del class="text-secondary ml-3 text-sm font-normal">$<%= product.basePrice.toLocaleString() %></del>
                <% } else { %>
                    <span class="text-secondary">$<%= product.basePrice.toLocaleString() %></span>
                <% } %>
            </div>

            <p class="font-body-md text-body-md text-on-surface-variant mb-8 leading-relaxed">
                <%= product.description %>
            </p>
        </div>
    </main>

    <%- include('partials/footer') %>

    <div class="mobile-only fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-xl border-t border-gray-100 px-6 py-4 z-50 flex items-center justify-between shadow-[0_-8px_30px_rgb(0,0,0,0.02)]">
        <div class="flex flex-col">
            <span class="text-[10px] text-gray-400 uppercase tracking-widest font-semibold mb-0.5">Total Price</span>
            <span class="text-base font-semibold text-primary">$<%= displayPrice.toLocaleString() %></span>
        </div>
        
        <form action="/add-to-cart" method="POST" class="cart-form flex-grow max-w-[60%]">
            <input type="hidden" name="id" value="<%= product._id %>">
            <input type="hidden" name="name" value="<%= product.name %>">
            <input type="hidden" name="price" value="<%= displayPrice %>">
            <input type="hidden" name="image" id="mobile-form-img" value="<%= mainImage %>">
            
            <button type="submit" class="w-full bg-primary text-white font-medium text-xs uppercase tracking-[0.2em] py-3.5 px-4 rounded-none shadow-sm flex justify-center items-center gap-2 active:scale-[0.98] transition-transform">
                <span>Add to Bag</span>
                <span class="material-symbols-outlined text-[16px] text-white">arrow_forward</span>
            </button>
        </form>
    </div>

    <script>
        // Desktop Switcher Function Interactivity
        const desktopThumbnails = document.querySelectorAll('.thumbnail-btn');
        const desktopMainImg = document.getElementById('desktop-main-img');
        const desktopFormImg = document.getElementById('desktop-form-img');

        desktopThumbnails.forEach(btn => {
            btn.addEventListener('click', function() {
                const targetSrc = this.getAttribute('data-target-src');
                desktopMainImg.src = targetSrc;
                if(desktopFormImg) desktopFormImg.value = targetSrc;

                desktopThumbnails.forEach(t => t.classList.remove('ring-1', 'ring-primary', 'ring-offset-2', 'opacity-100'));
                desktopThumbnails.forEach(t => t.classList.add('opacity-60'));
                
                this.classList.add('ring-1', 'ring-primary', 'ring-offset-2', 'opacity-100');
                this.classList.remove('opacity-60');
            });
        });

        // Mobile Switcher Function Interactivity
        const mobileThumbnails = document.querySelectorAll('.mobile-thumbnail-btn');
        const mobileMainImg = document.getElementById('mobile-main-img');
        const mobileFormImg = document.getElementById('mobile-form-img');

        mobileThumbnails.forEach(btn => {
            btn.addEventListener('click', function() {
                const targetSrc = this.getAttribute('data-target-src');
                mobileMainImg.src = targetSrc;
                if(mobileFormImg) mobileFormImg.value = targetSrc;

                mobileThumbnails.forEach(t => t.classList.remove('ring-1', 'ring-primary', 'opacity-100'));
                mobileThumbnails.forEach(t => t.classList.add('opacity-60'));
                
                this.classList.add('ring-1', 'ring-primary', 'opacity-100');
                this.classList.remove('opacity-60');
            });
        });

        // Add to LocalStorage Handler
        document.querySelectorAll('.cart-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                const id = this.querySelector('input[name="id"]').value;
                const name = this.querySelector('input[name="name"]').value;
                const price = this.querySelector('input[name="price"]').value;
                const image = this.querySelector('input[name="image"]').value;

                let cart = JSON.parse(localStorage.getItem('cart')) || [];
                
                const existingProductIndex = cart.findIndex(item => item.id === id);
                if (existingProductIndex > -1) {
                    cart[existingProductIndex].quantity = (cart[existingProductIndex].quantity || 1) + 1;
                } else {
                    cart.push({ id, name, price: parseInt(price), image, quantity: 1 });
                }

                localStorage.setItem('cart', JSON.stringify(cart));
            });
        });
    </script>

</body>
</html>