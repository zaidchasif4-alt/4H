<!-- GLOBAL CURSOR DOT ONLY (ring removed) -->
<div id="cursor" style="width:6px;height:6px;background:#b8975a;border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .25s,height .25s,opacity .25s;opacity:0;"></div>

<header id="site-header" class="fixed top-0 w-full z-[100] transition-all duration-500" style="font-family:'Tenor Sans',sans-serif;">
    <div id="header-inner" class="flex justify-between items-center px-6 md:px-16 lg:px-20 py-5 max-w-[1440px] mx-auto transition-all duration-500">

        <!-- Left Nav (Desktop) -->
        <nav class="hidden md:flex items-center gap-8" id="desktop-nav">
            <a href="/" class="nav-link text-[10px] uppercase tracking-[0.3em] transition-all duration-300 hover:opacity-50">Shop</a>
            <a href="/collection" class="nav-link text-[10px] uppercase tracking-[0.3em] transition-all duration-300 hover:opacity-50">Collections</a>
            <a href="/about" class="nav-link text-[10px] uppercase tracking-[0.3em] transition-all duration-300 hover:opacity-50">About</a>
        </nav>

        <!-- Mobile Hamburger -->
        <button id="mobile-menu-btn" class="md:hidden focus:outline-none" aria-label="Menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
            </svg>
        </button>

        <!-- Center Logo -->
        <div class="absolute left-1/2 -translate-x-1/2">
            <a href="/" class="block" style="font-family:'Cormorant Garamond',serif;">
                <span class="text-2xl font-light tracking-[0.5em] uppercase">4H</span>
                <div class="text-[7px] tracking-[0.5em] uppercase text-center opacity-50" style="font-family:'Tenor Sans',sans-serif; letter-spacing:0.6em;">Timepieces</div>
            </a>
        </div>

        <!-- Right Icons -->
        <div class="flex items-center gap-5">
            <!-- Search -->
            <button id="search-trigger" class="hover:opacity-50 transition-all focus:outline-none" aria-label="Search">
                <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </button>

            <!-- Cart -->
            <a href="/cart" class="hover:opacity-50 transition-all relative focus:outline-none" aria-label="Cart">
                <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4H6z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
                <span class="cart-badge hidden absolute -top-2 -right-2 bg-[#b8975a] text-white text-[8px] font-bold w-4 h-4 rounded-full flex items-center justify-center">0</span>
            </a>

            <!-- WhatsApp -->
            <a href="#" id="whatsapp-btn" class="hidden md:flex hover:opacity-50 transition-all" aria-label="WhatsApp" target="_blank">
                <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
            </a>
        </div>
    </div>
</header>

<!-- Search Overlay -->
<div id="search-overlay" class="fixed inset-0 bg-white z-[200] flex items-center justify-center opacity-0 invisible transition-all duration-400" style="font-family:'Tenor Sans',sans-serif;">
    <button id="search-close" class="absolute top-6 right-8 text-[10px] uppercase tracking-[0.3em] hover:opacity-50 transition-all focus:outline-none">Close ✕</button>
    <div class="w-full max-w-2xl px-6">
        <p class="text-[9px] uppercase tracking-[0.5em] text-[#b8975a] mb-6 text-center">Search Collection</p>
        <div class="flex items-center border-b-2 border-black pb-3">
            <input
                id="search-input"
                type="text"
                placeholder="Search watches, collections..."
                class="flex-1 bg-transparent text-2xl font-light focus:outline-none placeholder:text-gray-300"
                style="font-family:'Cormorant Garamond',serif;"
                oninput="handleSearch(this.value)"
            />
            <svg class="w-5 h-5 text-gray-400 ml-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <div id="search-results" class="mt-8 space-y-4 max-h-80 overflow-y-auto"></div>
    </div>
</div>

<!-- Mobile Drawer -->
<div id="mobile-drawer" class="fixed inset-0 bg-[#faf9f7] z-[150] transform -translate-x-full transition-transform duration-400 ease-in-out md:hidden flex flex-col">
    <div class="flex justify-between items-center px-6 py-5 border-b border-black/10">
        <span style="font-family:'Cormorant Garamond',serif;" class="text-2xl font-light tracking-[0.5em] uppercase">4H</span>
        <button id="mobile-close-btn" class="focus:outline-none hover:opacity-50 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>
    <nav class="flex flex-col p-8 space-y-1" id="mobile-nav">
        <a href="/"           class="py-4 border-b border-black/5 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300">Shop</a>
        <a href="/collection" class="py-4 border-b border-black/5 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300">Collections</a>
        <a href="/about"      class="py-4 border-b border-black/5 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300">About</a>
        <a href="/contact"    class="py-4 border-b border-black/5 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300">Contact</a>
        <a href="/cart"       class="py-4 border-b border-black/5 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300">Cart</a>
        <!-- WhatsApp mobile link — hidden until number is set -->
        <a href="#" id="mobile-whatsapp-link" target="_blank"
           class="hidden py-4 text-[11px] uppercase tracking-[0.4em] hover:pl-3 transition-all duration-300 flex items-center gap-3 text-[#b8975a]">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>WhatsApp Us</span>
        </a>
    </nav>
    <div class="mt-auto p-8">
        <p class="text-[8px] uppercase tracking-[0.5em] text-[#b8975a]">4H Timepieces — Luxury Watches</p>
    </div>
</div>
<div id="drawer-overlay" class="fixed inset-0 bg-black/40 z-[145] hidden transition-opacity duration-300 opacity-0 md:hidden"></div>

<script>
(function() {
    // ── Cursor (simple gold dot, no ring) ────────────────────────────────────
    const cur = document.getElementById('cursor');
    if (!cur) return;

    document.addEventListener('mousemove', e => {
        cur.style.left    = e.clientX + 'px';
        cur.style.top     = e.clientY + 'px';
        cur.style.opacity = '1';
    });

    document.addEventListener('mouseleave', () => { cur.style.opacity = '0'; });

    document.addEventListener('mouseover', e => {
        if (e.target.closest('a, button')) {
            cur.style.width  = '10px';
            cur.style.height = '10px';
            cur.style.background = '#0a0a0a';
        } else {
            cur.style.width  = '6px';
            cur.style.height = '6px';
            cur.style.background = '#b8975a';
        }
    });

    // ── Header scroll effect ─────────────────────────────────────────────────
    const header = document.getElementById('site-header');
    const inner  = document.getElementById('header-inner');

    function updateHeader() {
        if (window.scrollY > 60) {
            header.style.background = 'rgba(250,249,247,0.95)';
            header.style.backdropFilter = 'blur(12px)';
            header.style.borderBottom = '1px solid rgba(10,10,10,0.08)';
            inner.style.paddingTop = '14px';
            inner.style.paddingBottom = '14px';
        } else {
            header.style.background = 'transparent';
            header.style.backdropFilter = 'none';
            header.style.borderBottom = 'none';
            inner.style.paddingTop = '20px';
            inner.style.paddingBottom = '20px';
        }
    }
    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();

    // ── Active nav link ───────────────────────────────────────────────────────
    const currentPath = window.location.pathname;
    document.querySelectorAll('#desktop-nav .nav-link, #mobile-nav a').forEach(link => {
        if (link.getAttribute('href') === currentPath) {
            link.style.opacity = '0.4';
            link.style.borderBottom = '1px solid currentColor';
        }
    });

    // ── Mobile drawer ─────────────────────────────────────────────────────────
    const drawer  = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('drawer-overlay');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn= document.getElementById('mobile-close-btn');

    function openMenu() {
        drawer.classList.remove('-translate-x-full');
        overlay.classList.remove('hidden');
        setTimeout(() => overlay.classList.add('opacity-100'), 10);
        document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
        drawer.classList.add('-translate-x-full');
        overlay.classList.remove('opacity-100');
        setTimeout(() => overlay.classList.add('hidden'), 300);
        document.body.style.overflow = '';
    }

    if (menuBtn)  menuBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    if (overlay)  overlay.addEventListener('click', closeMenu);

    // ── Cart badge ────────────────────────────────────────────────────────────
    function updateCartBadge() {
        try {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const count = cart.reduce((a, i) => a + (i.quantity || 1), 0);
            document.querySelectorAll('.cart-badge').forEach(b => {
                b.textContent = count;
                count > 0 ? b.classList.remove('hidden') : b.classList.add('hidden');
            });
        } catch(e) {}
    }
    updateCartBadge();
    window.addEventListener('storage', updateCartBadge);

    // ── Search overlay ─────────────────────────────────────────────────────────
    const searchOverlay = document.getElementById('search-overlay');
    const searchTrigger = document.getElementById('search-trigger');
    const searchClose   = document.getElementById('search-close');
    const searchInput   = document.getElementById('search-input');

    if (searchTrigger) {
        searchTrigger.addEventListener('click', () => {
            searchOverlay.style.opacity = '1';
            searchOverlay.style.visibility = 'visible';
            document.body.style.overflow = 'hidden';
            setTimeout(() => searchInput && searchInput.focus(), 300);
        });
    }
    if (searchClose) {
        searchClose.addEventListener('click', () => {
            searchOverlay.style.opacity = '0';
            searchOverlay.style.visibility = 'hidden';
            document.body.style.overflow = '';
        });
    }
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            searchOverlay.style.opacity = '0';
            searchOverlay.style.visibility = 'hidden';
            document.body.style.overflow = '';
        }
    });

    // ── WhatsApp — har page par kaam kare ────────────────────────────────────
    // Pehle data-whatsapp check karo, phir API se fetch karo
    async function setupWhatsApp() {
        let waNum = document.body.dataset.whatsapp || '';

        // Agar body mein nahi hai to API se lo
        if (!waNum) {
            try {
                const resp = await fetch('/api/whatsapp-number');
                const data = await resp.json();
                waNum = data.number || '';
            } catch(e) {}
        }

        if (!waNum) return;

        const cleanNum = waNum.replace(/[^0-9]/g, '');
        const waUrl    = 'https://wa.me/' + cleanNum;

        // Desktop header button
        const waBtn = document.getElementById('whatsapp-btn');
        if (waBtn) {
            waBtn.href = waUrl;
            waBtn.classList.remove('hidden');
            waBtn.classList.add('flex');
        }

        // Mobile drawer WhatsApp link
        const mobileWa = document.getElementById('mobile-whatsapp-link');
        if (mobileWa) {
            mobileWa.href = waUrl;
            mobileWa.classList.remove('hidden');
        }
    }
    setupWhatsApp();

})();

// Search function (global so oninput can call it)
function handleSearch(query) {
    const resultsEl = document.getElementById('search-results');
    if (!query || query.length < 2) { resultsEl.innerHTML = ''; return; }

    fetch('/collection?q=' + encodeURIComponent(query))
        .then(r => r.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const cards = doc.querySelectorAll('.product-card a[href^="/product/"]');
            const seen = new Set();
            const items = [];
            cards.forEach(card => {
                const href = card.getAttribute('href');
                if (!seen.has(href)) {
                    seen.add(href);
                    const img   = card.querySelector('img');
                    const title = card.closest('.product-card')?.querySelector('h3')?.textContent?.trim() || '';
                    const price = card.closest('.product-card')?.querySelector('.font-label')?.textContent?.trim() || '';
                    if (title) items.push({ href, img: img?.src, title, price });
                }
            });
            if (items.length === 0) {
                resultsEl.innerHTML = '<p style="font-family:\'Tenor Sans\',sans-serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#6b6560;">No results found</p>';
                return;
            }
            resultsEl.innerHTML = items.slice(0, 5).map(i => `
                <a href="${i.href}" class="flex items-center gap-4 py-3 border-b border-black/5 hover:opacity-60 transition-opacity">
                    <img src="${i.img}" class="w-12 h-14 object-cover bg-gray-100 shrink-0" />
                    <div>
                        <p style="font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;">${i.title}</p>
                        <p style="font-family:'Tenor Sans',sans-serif;font-size:9px;letter-spacing:0.2em;color:#b8975a;">${i.price}</p>
                    </div>
                </a>
            `).join('');
        })
        .catch(() => {});
}
</script>
