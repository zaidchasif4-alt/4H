<script>
    // WhatsApp footer link
    const waNum = document.body.dataset.whatsapp;
    const footerWa = document.getElementById('footer-whatsapp');
    if (footerWa && waNum) footerWa.href = 'https://wa.me/' + waNum.replace(/[^0-9]/g,'');
</script>
