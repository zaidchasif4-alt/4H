<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>4H Premium Store</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet"/>
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#000000",
                        "surface": "#f9f9f9",
                        "secondary": "#5d5f5f",
                        "outline-variant": "#c4c7c7"
                    },
                    fontFamily: {
                        "headline": ["Playfair Display", "serif"],
                        "body": ["Inter", "sans-serif"]
                    },
                    spacing: {
                        "gutter": "32px",
                        "container-max": "1440px",
                        "margin-desktop": "80px",
                        "margin-mobile": "20px"
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom Smooth Scroll & Blur Fix */
        .glass-header {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="bg-surface text-on-surface antialiased min-h-screen flex flex-col">